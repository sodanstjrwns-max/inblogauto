{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "inblog-autopublish",
  "compatibility_date": "2026-03-22",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "inblog-autopublish-db",
      "database_id": "local-dev-db"
    }
  ],
  // Cron Trigger: 매일 KST 06:50 (= UTC 21:50)
  // 프로덕션 배포 후 Cloudflare Dashboard에서 확인 가능
  "triggers": {
    "crons": ["50 21 * * *"]
  }
}
