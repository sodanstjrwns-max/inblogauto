{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "inblog-autopublish",
  "compatibility_date": "2026-03-22",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "inblog-autopublish-db",
      "database_id": "de755705-09d2-46ab-9567-7ecae42f3926"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "inblog-autopublish-images"
    }
  ],
  "triggers": {
    "crons": [
      "0 17 * * *",
      "0 18 * * *",
      "0 19 * * *",
      "0 20 * * *",
      "30 20 * * *"
    ]
  }
}
